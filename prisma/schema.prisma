generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(cuid())
  name       String
  email      String      @unique
  password   String
  role       Role
  department Department?
  createdAt  DateTime    @default(now())
}

enum Role {
  ADMIN
  STAFF
  CLIENT
}

enum Department {
  MARKETING
  SALES
  COORDINATOR
  OPERATION
}